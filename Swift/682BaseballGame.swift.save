\class Solution {
    func calPoints(_ operations: [String]) -> Int {
        var stack = [Int]()
        for op in operations {
            if let num = Int(op) {
                // is a number
                stack.append(num)
            } else {
                // is C, D, +
                if op == "C" {
                    stack.popLast()
                } else if op == "D" {
                    let last = stack.last ?? 0
                    stack.append(last * 2)
                } else {
                    // +
                    let top = stack[stack.count - 1]
                    let secondTop = stack[stack.count - 2]
                    stack.append(top + secondTop)
                }
            }
        }
        return stack.reduce(0, +)
    }
}
